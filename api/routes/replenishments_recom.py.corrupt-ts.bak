import DashboardLayout from '../layouts/DashboardLayout';
import {
  BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, Legend,
  ResponsiveContainer
} from 'recharts';
import {
  Package, Truck, TrendingUp,
  ChevronLeft, ChevronRight, BarChart2, Activity,
  Layers, ArrowUpDown, ArrowDown, ArrowUp, Database, X, Box, ArrowRight,
  Search, Store, Calendar, RotateCcw, Hash, Download, History
} from 'lucide-react';
import { FilterDropdown } from '../components/FilterDropdown';
import { RetailValueSkeleton } from '../components/RetailLoader';
import { ReplenishmentLineLoader } from '../components/ReplenishmentLineLoader';
import InfoTooltip from '../components/InfoTooltip';
import { PriorityScoreRawTooltip } from '../components/PriorityScoreRawTooltip';
import { useFilters } from '../contexts/SeasonContext';
